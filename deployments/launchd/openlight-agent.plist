<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.openlight.agent</string>

	<key>ProgramArguments</key>
	<array>
		<string>/Users/macmini/openlight</string>
		<string>agent</string>
		<string>-config</string>
		<string>/etc/openlight/agent.yaml</string>
	</array>

	<key>WorkingDirectory</key>
	<string>/Users/macmini</string>

	<key>UserName</key>
	<string>macmini</string>

	<key>RunAtLoad</key>
	<true/>

	<key>KeepAlive</key>
	<true/>

	<key>StandardOutPath</key>
	<string>/Users/macmini/Library/Logs/openlight-agent.log</string>

	<key>StandardErrorPath</key>
	<string>/Users/macmini/Library/Logs/openlight-agent.error.log</string>
</dict>
</plist>
