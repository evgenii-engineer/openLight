# openLight environment example.
#
# Copy to .env (gitignored) and fill in. Only variables you actually use need to
# be set. See README "Configuration reference" for the full list.

# --- Core ---
# TELEGRAM_BOT_TOKEN=
# ALLOWED_USER_IDS=123456789
# ALLOWED_CHAT_IDS=123456789
# SQLITE_PATH=./data/openlight.sqlite

# --- Local private modules (off by default) ---
# When enabled, openLight activates the compiled-in modules listed below.
# See README "Local private modules".
OPENLIGHT_LOCAL_MODULES_ENABLED=false
OPENLIGHT_LOCAL_MODULES_PATH=./local_modules
# Comma-separated module names, e.g. munch_monitor,another_private_module
OPENLIGHT_LOCAL_MODULES=

# Private module secrets live in local_modules/<name>/ READMEs and this .env.
# They are read from the environment only and are never committed.
